#!/bin/bash
echo
echo "#################################"
echo "Start Services"
echo "#################################"

echo "Permission of root"
echo "#################################"
chmod -v 750 /root

echo "Bluetooth improvements"
echo "#################################"
sed -i "s/#AutoEnable=false/AutoEnable=true/g" /etc/bluetooth/main.conf

echo "#################################"
echo "End services"
echo "#################################"
rm /usr/local/bin/services

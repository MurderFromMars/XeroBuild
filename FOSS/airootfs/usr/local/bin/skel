#!/usr/bin/env bash
echo
echo "#################################"
echo "Moving content from skel"
echo "#################################"

for dir in /home/*/; do
  [[ -d "$dir" ]] || continue
  user=$(basename "$dir")
  echo "Copying skel to $user..."
  su -s "/bin/bash" -c "cp -aT /etc/skel/ /home/$user/" "$user" || echo "Warning: Failed for $user"
done

rm /usr/local/bin/skel
#!/bin/bash

# Logo image path
LOGO="/usr/share/logos/xero.png"
RESIZED_LOGO="/tmp/resized_logo.png"

# Resize logo
convert "$LOGO" -resize 150x150 "$RESIZED_LOGO"

# Friendly header message
HEADER=$'<b>WELCOME TO XEROLINUX!</b>\n\nPlease make sure you are connected to the Internet <b>before launching the installer</b>.\nWi-Fi will work, but a wired connection is strongly recommended for faster downloads.\n\n<span foreground="red"><b>Without an active Internet connection, installation will fail.</b></span>'

# Clean launcher – no BODY text, no scrollbox, no visual chaos
yad --center \
    --title="XeroLinux Launcher" \
    --width=400 --height=220 \
    --fixed \
    --image="$RESIZED_LOGO" \
    --image-on-top \
    --text="$HEADER" \
    --markup \
    --buttons-layout=center \
    --button="Main Site!:1" \
    --button="<b>Launch Installer</b>!:2" \
    --button="Discord!:3"

exit_code=$?

case $exit_code in
    1) xdg-open "https://xerolinux.xyz" ;;
    2) sudo calamares ;;
    3) xdg-open "https://discord.xerolinux.xyz" ;;
    *) ;;
esac
